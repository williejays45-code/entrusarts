# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python generated files
__pycache__/
*.py[cod]
.pytest_cache/
/pytest-cache-files-*/

# ERA runtime databases and journals
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ERA generated reports and temporary artifact stores
/verification_reports/
/era/artifact_storage/era-art001-*/
/LIVE_DCAD_VERIFY_*.log

# Real external DCAD excerpts; replace with synthetic fixtures
/era/live_adapters/fixtures/
